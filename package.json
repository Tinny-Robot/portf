{
  "name": "nathaniel-handan-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Dynamic static-first portfolio with reviews, contact and lightweight analytics APIs.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "docker:build": "docker build -t nathaniel-portfolio .",
